# ════════════════════════════════════════════════════════════════════
# ALPHA NETWORK — Variáveis de Ambiente
# Copia este ficheiro para .env.local e preenche os valores
# NUNCA commites o ficheiro .env.local
# ════════════════════════════════════════════════════════════════════

# ─── Base de Dados ───────────────────────────────────────────────────
DATABASE_URL="postgresql://alpha:alpha_dev_password@localhost:5432/alpha_network"

# ─── Redis ───────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── JWT (gerar com: openssl rand -hex 32) ───────────────────────────
JWT_ACCESS_SECRET="substitui_por_valor_gerado_com_openssl"
JWT_REFRESH_SECRET="substitui_por_outro_valor_diferente"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── Google OAuth ────────────────────────────────────────────────────
# Obter em: console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3001/api/v1/auth/google/callback"

# ─── MinIO / S3 (storage de ficheiros) ──────────────────────────────
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="alpha_minio"
S3_SECRET_KEY="alpha_minio_secret"
S3_BUCKET_NAME="alpha-uploads"
S3_REGION="us-east-1"

# ─── API ─────────────────────────────────────────────────────────────
API_PORT=3001
API_URL="http://localhost:3001"
FRONTEND_URL="http://localhost:3000"
NODE_ENV="development"

# ─── Next.js (frontend) ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_WS_URL="http://localhost:3001"
