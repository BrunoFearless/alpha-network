{
  "name": "alpha-network",
  "version": "1.0.0",
  "private": true,
  "description": "Alpha Network — Plataforma social adaptativa",
  "scripts": {
    "postinstall": "pnpm --filter @alpha/api db:generate",
    "dev": "concurrently \"pnpm --filter @alpha/api dev\" \"pnpm --filter @alpha/web dev\"",
    "build": "pnpm --filter @alpha/api build && pnpm --filter @alpha/web build",
    "lint": "pnpm -r lint",
    "test": "pnpm --filter @alpha/api test",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @alpha/api db:generate",
    "db:migrate": "pnpm --filter @alpha/api db:migrate",
    "db:studio": "pnpm --filter @alpha/api db:studio",
    "db:seed": "pnpm --filter @alpha/api db:seed"
  },
  "devDependencies": {
    "@types/multer": "^2.1.0",
    "concurrently": "^8.2.2",
    "prisma": "^5.22.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  }
}
