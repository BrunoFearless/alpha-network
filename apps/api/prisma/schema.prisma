generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Friendship {
  id        String   @id @default(uuid())
  userId    String
  friendId  String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  friend    User     @relation("FriendshipFriend", fields: [friendId], references: [id], onDelete: Cascade)
  user      User     @relation("FriendshipUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
  @@map("friendships")
}

model User {
  id                        String                 @id @default(uuid())
  email                     String                 @unique
  passwordHash              String?
  provider                  String                 @default("email")
  emailVerified             Boolean                @default(false)
  createdAt                 DateTime               @default(now())
  updatedAt                 DateTime               @updatedAt
  deletedAt                 DateTime?
  alphaAI                   AlphaAI?
  alphaCoreActions          AlphaCoreAction[]
  alphaCorePermission       AlphaCorePermission?
  chatMessages              ChatMessage[]
  friendOf                  Friendship[]           @relation("FriendshipFriend")
  friendships               Friendship[]           @relation("FriendshipUser")
  lazerCheckIns             LazerCheckIn[]
  lazerComments             LazerComment[]
  lazerCommunitiesOwned     LazerCommunity[]       @relation("LazerCommunityOwner")
  lazerCommunityMemberships LazerCommunityMember[]
  lazerPosts                LazerPost[]
  lazerReactions            LazerReaction[]
  profile                   Profile?
  sessions                  Session[]
  chatConversations         ChatConversation[]     @relation("UserConversations")

  @@map("users")
}

model Profile {
  id                  String   @id @default(uuid())
  userId              String   @unique
  username            String   @unique
  displayName         String?
  avatarUrl           String?
  bannerUrl           String?
  bannerColor         String?
  bio                 String?
  status              String?
  tags                String?
  lazerData           Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  activeModes         String[] @default([])
  auroraTheme         String?
  nameColor           String?
  nameEffect          String?
  nameFont            String?
  lastPlayedTrack     Json?
  spotifyEnabled      Boolean  @default(false)
  spotifyRefreshToken String?
  youtubeChannelId    String?
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model LazerPost {
  id          String          @id @default(uuid())
  authorId    String
  content     String
  imageUrl    String?
  titleFont   String?
  titleColor  String?
  isSparkle   Boolean         @default(false)
  isPinned    Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?
  communityId String?
  comments    LazerComment[]
  author      User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  community   LazerCommunity? @relation(fields: [communityId], references: [id], onDelete: Cascade)
  reactions   LazerReaction[]
  tropes      LazerTrope[]    @relation("LazerPostToLazerTrope")

  @@map("lazer_posts")
}

model LazerReaction {
  id        String    @id @default(uuid())
  postId    String
  userId    String
  type      String    @default("like")
  createdAt DateTime  @default(now())
  post      LazerPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("lazer_reactions")
}

model LazerComment {
  id        String    @id @default(uuid())
  postId    String
  authorId  String
  content   String
  createdAt DateTime  @default(now())
  deletedAt DateTime?
  parentId  String?
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  post      LazerPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@map("lazer_comments")
}

model LazerTrope {
  id          String      @id @default(uuid())
  name        String      @unique
  description String?
  iconEmoji   String      @default("✨")
  category    String      @default("General")
  createdAt   DateTime    @default(now())
  posts       LazerPost[] @relation("LazerPostToLazerTrope")

  @@map("lazer_tropes")
}

model LazerTropeTrend {
  id            String   @id @default(uuid())
  tropeId       String
  date          DateTime
  sparklesCount Int      @default(0)
  talkingCount  Int      @default(0)
  rank          Int?

  @@unique([tropeId, date])
  @@map("lazer_trope_trends")
}

model LazerCheckIn {
  id        String   @id @default(uuid())
  userId    String
  title     String
  episode   String
  emoji     String
  genre     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([title, createdAt])
  @@map("lazer_checkins")
}

model LazerCommunity {
  id               String                 @id @default(uuid())
  ownerId          String
  name             String
  description      String?
  bannerUrl        String?
  iconUrl          String?
  iconEmoji        String                 @default("🌐")
  youtubeChannelId String?
  accentColor      String?                @default("#fbbf24")
  themeColor       String?                @default("#fbbf24")
  isPublic         Boolean                @default(true)
  inviteCode       String                 @unique
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  deletedAt        DateTime?
  owner            User                   @relation("LazerCommunityOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members          LazerCommunityMember[]
  rules            LazerCommunityRule[]
  posts            LazerPost[]

  @@map("lazer_communities")
}

model LazerCommunityMember {
  id          String         @id @default(uuid())
  communityId String
  userId      String
  role        String         @default("member")
  joinedAt    DateTime       @default(now())
  community   LazerCommunity @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId])
  @@map("lazer_community_members")
}

model LazerCommunityRule {
  id          String         @id @default(uuid())
  communityId String
  text        String
  createdAt   DateTime       @default(now())
  community   LazerCommunity @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@map("lazer_community_rules")
}

model CreatorArticle {
  id          String    @id @default(uuid())
  authorId    String
  title       String
  content     String
  slug        String    @unique
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@map("creator_articles")
}

model CreatorPortfolioItem {
  id          String   @id @default(uuid())
  authorId    String
  title       String
  description String?
  link        String?
  imageUrl    String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("creator_portfolio_items")
}

model DevProject {
  id          String       @id @default(uuid())
  ownerId     String
  name        String
  description String?
  isPublic    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?
  files       DevFile[]
  members     DevMember[]
  messages    DevMessage[]
  tasks       DevTask[]

  @@map("dev_projects")
}

model DevMember {
  id        String     @id @default(uuid())
  projectId String
  userId    String
  role      String     @default("member")
  joinedAt  DateTime   @default(now())
  project   DevProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("dev_members")
}

model DevFile {
  id        String     @id @default(uuid())
  projectId String
  name      String
  path      String
  content   String     @default("")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  project   DevProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, path])
  @@map("dev_files")
}

model DevTask {
  id          String     @id @default(uuid())
  projectId   String
  createdById String
  title       String
  completed   Boolean    @default(false)
  createdAt   DateTime   @default(now())
  project     DevProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("dev_tasks")
}

model DevMessage {
  id        String     @id @default(uuid())
  projectId String
  authorId  String
  content   String
  createdAt DateTime   @default(now())
  project   DevProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("dev_messages")
}

model Server {
  id                String              @id @default(uuid())
  ownerId           String
  name              String
  description       String?
  imageUrl          String?
  bannerUrl         String?
  bannerColor       String?
  inviteCode        String              @unique @default(uuid())
  createdAt         DateTime            @default(now())
  deletedAt         DateTime?
  auditLogs         CommunityAuditLog[]
  bans              CommunityBan[]
  channelCategories ChannelCategory[]
  channels          Channel[]
  events            CommunityEvent[]
  members           ServerMember[]
  roles             CommunityRole[]
  bots              ServerBot[]

  @@map("community_servers")
}

model ChannelCategory {
  id        String    @id @default(uuid())
  serverId  String
  name      String
  icon      String    @default("📁")
  position  Int       @default(0)
  createdAt DateTime  @default(now())
  server    Server    @relation(fields: [serverId], references: [id], onDelete: Cascade)
  channels  Channel[]

  @@map("community_channel_categories")
}

model CommunityAuditLog {
  id        String   @id @default(uuid())
  serverId  String
  actorId   String
  action    String
  targetId  String?
  metadata  Json?
  createdAt DateTime @default(now())
  server    Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId, createdAt(sort: Desc)])
  @@map("community_audit_logs")
}

model CommunityRole {
  id                String         @id @default(uuid())
  serverId          String
  name              String
  color             String?
  position          Int            @default(0)
  canModerate       Boolean        @default(false)
  canManageServer   Boolean        @default(false)
  canManageChannels Boolean        @default(false)
  createdAt         DateTime       @default(now())
  members           ServerMember[]
  server            Server         @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([serverId, name])
  @@map("community_roles")
}

model CommunityBan {
  id        String   @id @default(uuid())
  serverId  String
  userId    String
  createdAt DateTime @default(now())
  server    Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([serverId, userId])
  @@map("community_bans")
}

model Channel {
  id              String           @id @default(uuid())
  serverId        String
  categoryId      String?
  parentId        String?
  parentMessageId String?
  name            String
  topic           String?
  type            String           @default("text")
  icon            String           @default("#")
  position        Int              @default(0)
  isPrivate       Boolean          @default(false)
  allowedRoles    Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  category        ChannelCategory? @relation(fields: [categoryId], references: [id])
  parent          Channel?         @relation("ThreadParent", fields: [parentId], references: [id], onDelete: Cascade)
  threads         Channel[]        @relation("ThreadParent")
  server          Server           @relation(fields: [serverId], references: [id], onDelete: Cascade)
  messages        Message[]
  pins            PinnedMessage[]

  @@map("community_channels")
}

model Message {
  id             String            @id @default(uuid())
  channelId      String
  authorId       String
  authorType     String            @default("user")
  content        String
  messageType    String            @default("text")
  imageUrl       String?
  embedJson      Json?
  replyToId      String?
  editedAt       DateTime?
  attachmentUrls Json?
  mentions       Json?
  createdAt      DateTime          @default(now())
  deletedAt      DateTime?
  reactions      MessageReaction[]
  channel        Channel           @relation(fields: [channelId], references: [id], onDelete: Cascade)
  replyTo        Message?          @relation("MessageReply", fields: [replyToId], references: [id])
  replies        Message[]         @relation("MessageReply")
  pin            PinnedMessage?

  @@map("community_messages")
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@map("community_message_reactions")
}

model PinnedMessage {
  id        String   @id @default(uuid())
  channelId String
  messageId String   @unique
  pinnedBy  String
  pinnedAt  DateTime @default(now())
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([channelId, messageId])
  @@map("community_pinned_messages")
}

model ServerMember {
  id              String         @id @default(uuid())
  serverId        String
  userId          String
  role            String         @default("member")
  communityRoleId String?
  mutedUntil      DateTime?
  joinedAt        DateTime       @default(now())
  communityRole   CommunityRole? @relation(fields: [communityRoleId], references: [id])
  server          Server         @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([serverId, userId])
  @@map("community_members")
}

model CommunityEvent {
  id           String                   @id @default(uuid())
  serverId     String
  creatorId    String
  title        String
  description  String?
  location     String?
  locationType String                   @default("external")
  imageUrl     String?
  startDate    DateTime
  endDate      DateTime?
  frequency    String                   @default("none")
  coverColor   String?
  createdAt    DateTime                 @default(now())
  interests    CommunityEventInterest[]
  server       Server                   @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@map("community_events")
}

model CommunityEventInterest {
  id        String         @id @default(uuid())
  eventId   String
  userId    String
  createdAt DateTime       @default(now())
  event     CommunityEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@map("community_event_interests")
}

model Bot {
  id            String            @id @default(uuid())
  ownerId       String
  name          String
  description   String?
  avatarUrl     String?
  customColor   String            @default("#C9A84C")
  token         String            @unique @default(uuid())
  prefix        String            @default("!")
  builderFlow   Json?
  isPublic      Boolean           @default(false)
  version       Int               @default(1)
  createdAt     DateTime          @default(now())
  commands      BotCommand[]
  executionLogs BotExecutionLog[]
  servers       ServerBot[]

  @@map("bots")
}

model BotExecutionLog {
  id        String   @id @default(uuid())
  botId     String
  serverId  String
  channelId String
  kind      String
  ok        Boolean
  detail    Json?
  createdAt DateTime @default(now())
  bot       Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@index([botId, createdAt])
  @@map("bot_execution_logs")
}

model BotCommand {
  id           String  @id @default(uuid())
  botId        String
  trigger      String
  response     String
  responseType String  @default("text")
  imageUrl     String?
  embedJson    Json?
  bot          Bot     @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@unique([botId, trigger])
  @@map("bot_commands")
}

model ServerBot {
  id         String   @id @default(uuid())
  serverId   String
  botId      String
  isAdminBot Boolean  @default(false)
  addedAt    DateTime @default(now())
  bot        Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)
  server     Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([serverId, botId])
  @@map("server_bots")
}

model AlphaCoreAction {
  id          String    @id @default(uuid())
  userId      String
  action      String
  payload     Json
  result      Json?
  status      String    @default("pending")
  confirmedAt DateTime?
  executedAt  DateTime?
  revertedAt  DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("alpha_core_actions")
}

model AlphaCorePermission {
  id               String   @id @default(uuid())
  userId           String   @unique
  canEditProfile   Boolean  @default(false)
  canCreatePosts   Boolean  @default(false)
  canDeletePosts   Boolean  @default(false)
  canManageFriends Boolean  @default(false)
  canEditTheme     Boolean  @default(false)
  canEditAI        Boolean  @default(false)
  grantedAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("alpha_core_permissions")
}

model AlphaAI {
  id                 String           @id @default(uuid())
  userId             String           @unique
  name               String           @default("Alpha")
  botname            String           @unique
  tagline            String?
  bio                String?
  status             String?
  avatarUrl          String?
  bannerUrl          String?
  bannerColor        String?
  age                String?
  birthday           String?
  gender             String?
  appearance         String?
  backstory          String?
  personalityTraits  String[]
  tone               String?
  likes              String[]
  dislikes           String[]
  goals              String[]
  responseStyle      String?
  responseLength     String           @default("adaptive")
  customSystemPrompt String?
  personalityPrompt  String?
  knowledgePrompt    String?
  initialMessage     String?
  wakeupMessage      String?
  errorMessage       String?
  sleepMessage       String?
  trainingExamples   Json?
  knowledgeEntries   Json?
  triggerWords       Json?
  language           String           @default("pt")
  memoryEnabled      Boolean          @default(true)
  isPublic           Boolean          @default(false)
  isActive           Boolean          @default(true)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  messages           AlphaAiMessage[]
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("alpha_ais")
}

model AlphaAiMessage {
  id        String   @id @default(uuid())
  aiId      String
  role      String
  content   String
  createdAt DateTime @default(now())
  ai        AlphaAI  @relation(fields: [aiId], references: [id], onDelete: Cascade)

  @@index([aiId, createdAt])
  @@map("alpha_ai_messages")
}

model ChatConversation {
  id            String        @id @default(uuid())
  name          String?
  isGroup       Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  lastMessageAt DateTime      @default(now())
  messages      ChatMessage[]
  participants  User[]        @relation("UserConversations")

  @@map("chat_conversations")
}

model ChatMessage {
  id             String                @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  imageUrl       String?
  isPinned       Boolean               @default(false)
  editedAt       DateTime?
  createdAt      DateTime              @default(now())
  readAt         DateTime?
  conversation   ChatConversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User                  @relation(fields: [senderId], references: [id], onDelete: Cascade)
  reactions      ChatMessageReaction[]

  @@map("chat_messages")
}

model ChatMessageReaction {
  id        String      @id @default(uuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime    @default(now())
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@map("chat_message_reactions")
}
