// ════════════════════════════════════════════════════════════════════
// ALPHA NETWORK — Schema Prisma
// ════════════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── AUTH (Adolfo) ───────────────────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String?
  provider      String    @default("email")
  emailVerified Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  profile        Profile?
  sessions       Session[]
  lazerPosts     LazerPost[]
  lazerComments  LazerComment[]
  lazerReactions LazerReaction[]

  @@map("users")
}

model Profile {
  id          String  @id @default(uuid())
  userId      String  @unique
  username    String  @unique
  displayName String?
  avatarUrl   String?
  bannerUrl   String?
  bannerColor String?
  bio         String?
  status      String?
  tags        String?
  lazerData   Json?

  // Name styling
  nameFont   String?
  nameEffect String?
  nameColor  String?

  // Aurora theme
  auroraTheme String?

  // Active modes
  activeModes String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@map("follows")
}

// ─── MODO LAZER (Obed) ───────────────────────────────────────────────

model LazerPost {
  id         String    @id @default(uuid())
  authorId   String
  content    String
  imageUrl   String?
  tag        String?
  titleFont  String?
  titleColor String?
  isSparkle  Boolean   @default(false)
  isPinned   Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  reactions LazerReaction[]
  comments  LazerComment[]
  author    User            @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("lazer_posts")
}

model LazerReaction {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  type      String   @default("like")
  createdAt DateTime @default(now())

  post LazerPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("lazer_reactions")
}

model LazerComment {
  id        String    @id @default(uuid())
  postId    String
  authorId  String
  parentId  String?
  content   String
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  post   LazerPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User      @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("lazer_comments")
}

// ─── MODO CRIADOR (Pedro) ────────────────────────────────────────────

model CreatorArticle {
  id          String    @id @default(uuid())
  authorId    String
  title       String
  content     String
  slug        String    @unique
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@map("creator_articles")
}

model CreatorPortfolioItem {
  id          String   @id @default(uuid())
  authorId    String
  title       String
  description String?
  link        String?
  imageUrl    String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("creator_portfolio_items")
}

// ─── MODO DESENVOLVEDOR (Alexandre) ─────────────────────────────────

model DevProject {
  id          String    @id @default(uuid())
  ownerId     String
  name        String
  description String?
  isPublic    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  members  DevMember[]
  files    DevFile[]
  tasks    DevTask[]
  messages DevMessage[]

  @@map("dev_projects")
}

model DevMember {
  id        String   @id @default(uuid())
  projectId String
  userId    String
  role      String   @default("member")
  joinedAt  DateTime @default(now())

  project DevProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("dev_members")
}

model DevFile {
  id        String   @id @default(uuid())
  projectId String
  name      String
  path      String
  content   String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project DevProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, path])
  @@map("dev_files")
}

model DevTask {
  id          String   @id @default(uuid())
  projectId   String
  createdById String
  title       String
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())

  project DevProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("dev_tasks")
}

model DevMessage {
  id        String   @id @default(uuid())
  projectId String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  project DevProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("dev_messages")
}

// ─── MODO COMUNIDADE (Bruno) ─────────────────────────────────────────

model Server {
  id          String    @id @default(uuid())
  ownerId     String
  name        String
  description String?
  imageUrl    String?
  bannerUrl   String?
  bannerColor String?
  inviteCode  String    @unique @default(uuid())
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?

  channels          Channel[]
  channelCategories ChannelCategory[]
  members           ServerMember[]
  bots              ServerBot[]
  roles             CommunityRole[]
  bans              CommunityBan[]
  auditLogs         CommunityAuditLog[]
  events            CommunityEvent[]

  @@map("community_servers")
}

model ChannelCategory {
  id        String   @id @default(uuid())
  serverId  String
  name      String
  icon      String   @default("📁")
  position  Int      @default(0)
  createdAt DateTime @default(now())

  server   Server    @relation(fields: [serverId], references: [id], onDelete: Cascade)
  channels Channel[]

  @@map("community_channel_categories")
}

model CommunityAuditLog {
  id        String   @id @default(uuid())
  serverId  String
  actorId   String
  action    String
  targetId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId, createdAt(sort: Desc)])
  @@map("community_audit_logs")
}

model CommunityRole {
  id                String   @id @default(uuid())
  serverId          String
  name              String
  color             String?
  position          Int      @default(0)
  canModerate       Boolean  @default(false)
  canManageServer   Boolean  @default(false)
  canManageChannels Boolean  @default(false)
  createdAt         DateTime @default(now())

  server  Server         @relation(fields: [serverId], references: [id], onDelete: Cascade)
  members ServerMember[]

  @@unique([serverId, name])
  @@map("community_roles")
}

model CommunityBan {
  id        String   @id @default(uuid())
  serverId  String
  userId    String
  createdAt DateTime @default(now())

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([serverId, userId])
  @@map("community_bans")
}

model Channel {
  id              String   @id @default(uuid())
  serverId        String
  categoryId      String?
  parentId        String?
  parentMessageId String?
  name            String
  topic           String?
  type            String   @default("text")
  icon            String   @default("#")
  position        Int      @default(0)
  isPrivate       Boolean  @default(false)
  allowedRoles    Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  server   Server           @relation(fields: [serverId], references: [id], onDelete: Cascade)
  category ChannelCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  parent   Channel?         @relation("ThreadParent", fields: [parentId], references: [id], onDelete: Cascade)
  threads  Channel[]        @relation("ThreadParent")
  messages Message[]
  pins     PinnedMessage[]

  @@map("community_channels")
}

model Message {
  id             String    @id @default(uuid())
  channelId      String
  authorId       String
  authorType     String    @default("user")
  content        String
  messageType    String    @default("text")
  imageUrl       String?
  embedJson      Json?
  replyToId      String?
  editedAt       DateTime?
  attachmentUrls Json?
  mentions       Json?
  createdAt      DateTime  @default(now())
  deletedAt      DateTime?

  channel   Channel           @relation(fields: [channelId], references: [id], onDelete: Cascade)
  replyTo   Message?          @relation("MessageReply", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   Message[]         @relation("MessageReply")
  reactions MessageReaction[]
  pin       PinnedMessage?

  @@map("community_messages")
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@map("community_message_reactions")
}

model PinnedMessage {
  id        String   @id @default(uuid())
  channelId String
  messageId String   @unique
  pinnedBy  String
  pinnedAt  DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([channelId, messageId])
  @@map("community_pinned_messages")
}

model ServerMember {
  id              String    @id @default(uuid())
  serverId        String
  userId          String
  role            String    @default("member")
  communityRoleId String?
  mutedUntil      DateTime?
  joinedAt        DateTime  @default(now())

  server        Server         @relation(fields: [serverId], references: [id], onDelete: Cascade)
  communityRole CommunityRole? @relation(fields: [communityRoleId], references: [id], onDelete: SetNull)

  @@unique([serverId, userId])
  @@map("community_members")
}

model CommunityEvent {
  id           String    @id @default(uuid())
  serverId     String
  creatorId    String
  title        String
  description  String?
  location     String?
  locationType String    @default("external")
  imageUrl     String?
  startDate    DateTime
  endDate      DateTime?
  frequency    String    @default("none")
  coverColor   String?
  createdAt    DateTime  @default(now())

  server    Server                   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  interests CommunityEventInterest[]

  @@map("community_events")
}

model CommunityEventInterest {
  id        String   @id @default(uuid())
  eventId   String
  userId    String
  createdAt DateTime @default(now())

  event CommunityEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@map("community_event_interests")
}

// ─── MODO BOT (Bruno) ────────────────────────────────────────────────

model Bot {
  id          String   @id @default(uuid())
  ownerId     String
  name        String
  description String?
  avatarUrl   String?
  customColor String   @default("#C9A84C")
  token       String   @unique @default(uuid())
  prefix      String   @default("!")
  builderFlow Json?
  isPublic    Boolean  @default(false)
  version     Int      @default(1)
  createdAt   DateTime @default(now())

  commands      BotCommand[]
  servers       ServerBot[]
  executionLogs BotExecutionLog[]

  @@map("bots")
}

model BotExecutionLog {
  id        String   @id @default(uuid())
  botId     String
  serverId  String
  channelId String
  kind      String
  ok        Boolean
  detail    Json?
  createdAt DateTime @default(now())

  bot Bot @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@index([botId, createdAt])
  @@map("bot_execution_logs")
}

model BotCommand {
  id           String  @id @default(uuid())
  botId        String
  trigger      String
  response     String
  responseType String  @default("text")
  imageUrl     String?
  embedJson    Json?

  bot Bot @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@unique([botId, trigger])
  @@map("bot_commands")
}

model ServerBot {
  id         String   @id @default(uuid())
  serverId   String
  botId      String
  isAdminBot Boolean  @default(false)
  addedAt    DateTime @default(now())

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  bot    Bot    @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@unique([serverId, botId])
  @@map("server_bots")
}
