# Copiar para .env na mesma pasta (Prisma e Nest leem DATABASE_URL daqui).
# Valores alinhados ao docker-compose.yml na raiz do monorepo.

DATABASE_URL="postgresql://alpha:alpha_dev_password@localhost:5432/alpha_network"

GROQ_API_KEY="gsk_..."
# Modelos disponíveis (por ordem de qualidade vs. tokens):
# llama-3.3-70b-versatile  → melhor qualidade (100k TPD no free tier)
# llama-3.1-8b-instant     → rápido e económico (default, ~14M TPD)
# gemma2-9b-it             → alternativa Google
GROQ_MODEL="llama-3.1-8b-instant"

JWT_ACCESS_SECRET="gere-com-openssl-rand-hex-32"
JWT_REFRESH_SECRET="gere-com-openssl-rand-hex-32"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3001/api/v1/auth/google/callback"

API_PORT=3001
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"
