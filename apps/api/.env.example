# Copiar para .env na mesma pasta (Prisma e Nest leem DATABASE_URL daqui).
# Valores alinhados ao docker-compose.yml na raiz do monorepo.

DATABASE_URL="postgresql://alpha:alpha_dev_password@localhost:5432/alpha_network"

JWT_ACCESS_SECRET="gere-com-openssl-rand-hex-32"
JWT_REFRESH_SECRET="gere-com-openssl-rand-hex-32"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3001/api/v1/auth/google/callback"

API_PORT=3001
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"
